# MachauSilk Backend Environment Variables
# Copy this file to .env and update values

# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=machausilk

# JWT
JWT_SECRET=machausilk_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:5500
